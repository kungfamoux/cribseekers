{
  "name": "cribseekers",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for the CribSeekers real estate platform",
  "workspaces": [
    "apps/api",
    "packages/config",
    "packages/eslint-config",
    "packages/tsconfig",
    "packages/types",
    "packages/validation"
  ],
  "scripts": {
    "build": "cd apps/api && npm run build",
    "dev": "cd apps/api && npm run dev",
    "lint": "cd apps/api && npm run lint",
    "format": "cd apps/api && npm run format",
    "typecheck": "cd apps/api && npm run typecheck",
    "test": "cd apps/api && npm run test",
    "clean": "cd apps/api && npm run clean",
    "start": "node apps/api/dist/apps/api/src/main",
    "postinstall": "cd apps/api && npx prisma generate",
    "db:generate": "cd apps/api && npx prisma generate",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:migrate:deploy": "cd apps/api && npx prisma migrate deploy",
    "db:migrate:status": "cd apps/api && npx prisma migrate status",
    "db:push": "cd apps/api && npx prisma db push",
    "db:seed": "cd apps/api && npx prisma db seed",
    "db:studio": "cd apps/api && npx prisma studio"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "turbo": "^1.11.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
